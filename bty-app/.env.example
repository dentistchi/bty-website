# JWT secret (production에서 반드시 변경)
JWT_SECRET=your-secret-here

# Gemini API (Safe Mirror 안전한 거울). 없으면 고정 폴백 응답 사용
GEMINI_API_KEY=

# OpenAI API (채팅 AI · 멘토 · Action Contract Layer 2 validator). Safe Mirror는 GEMINI_API_KEY 사용
# Production: 반드시 설정 — 미설정 시 L2·멘토 경로 실패 가능 (로컬/CI만이 아님)
OPENAI_API_KEY=

# Action contract semantic validator (VALIDATOR_ARCHITECTURE_V1); default gpt-4o-mini, temperature 0.2 in code
BTY_VALIDATOR_OPENAI_MODEL=

# bty-ai-core (Leadership Reflection chat)
NEXT_PUBLIC_BTY_AI_URL=http://localhost:4000

# Admin (Quality Events, Patch Reports - server-side only)
ADMIN_API_KEY=

# 디버그 페이지 「패치 생성 및 배포」 클릭 시 호출할 배포 웹훅 (예: Cloudflare Pages Deploy Hook)
DEPLOY_WEBHOOK_URL=

# Microsoft Entra ID (Azure AD) for Admin Dashboard
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=
BTY_ADMIN_EMAILS=ywamer2022@gmail.com

# 멤버십 승인 알림 (Arena 가입 요청 시 Admin 이메일 발송. 없으면 로그만 출력)
RESEND_API_KEY=
RESEND_FROM=

# Center(구 Dear Me) / BTY 사이트 URL (로그인·리다이렉트용)
NEXT_PUBLIC_CENTER_URL=http://localhost:3000
NEXT_PUBLIC_BTY_URL=http://localhost:3001

# 대시보드 Arena Level 카드 노출 (PROJECT_BACKLOG §2). true 또는 미설정=노출, false=MVP 이후 숨김
NEXT_PUBLIC_SHOW_ARENA_LEVELS=true

# Arena session/next: set to 1 to enable legacy mod-3 mirror + perspective_switch rotation (default: catalog only).
# ARENA_SESSION_MIRROR_ROTATION_ENABLED=

# Arena pipeline: `legacy` (Pipeline L, default if unset/invalid) | `new` (Pipeline N). See ENGINE_ARCHITECTURE_V1.md §6.
# ARENA_PIPELINE_DEFAULT=legacy
# When server is `new`, set the same on client-only surfaces (e.g. ScenarioSessionShell).
# NEXT_PUBLIC_ARENA_PIPELINE_DEFAULT=new

# Post-login: default = forced Elite V2 canonical Arena (skip language/role/AIR/learning-path wizard + beginner redirect).
# Set to 1 to restore legacy onboarding (middleware → /onboarding) and beginner path (GET /api/arena/core-xp).
# BTY_POST_LOGIN_ONBOARDING_ENABLED=1
# NEXT_PUBLIC_BTY_POST_LOGIN_ONBOARDING_ENABLED=1

# Arena runtime is fixed to the Elite v2 chain allowlist (catalog-only).
# Optional: first-time Arena session (empty play history ∪ no DONE runs) uses this scenario id instead of core_01_training_system — e.g. vertical-slice proof (OWN-RE-02-R1). Must be an elite chain id.
# BTY_ARENA_VERTICAL_SLICE_ENTRY_SCENARIO_ID=OWN-RE-02-R1

# Local only: middleware allows /[locale]/bty-arena without login when NODE_ENV is not production. Do not set in prod.
# NEXT_PUBLIC_BTY_DEV_BYPASS_AUTH=true

# Supabase (BTY Journey 28일 진행 저장)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Verify app ↔ Dashboard same project: host must be `https://<project-ref>.supabase.co`
# (Supabase Dashboard → Project Settings → General → Reference ID). If schema edits in the Dashboard
# do not match runtime errors, compare that ref to the subdomain of NEXT_PUBLIC_SUPABASE_URL.

# Optional: POST /api/action-contracts includes `debug` (Supabase message/code) on error JSON — use only on trusted hosts.
# BTY_ACTION_CONTRACT_ROUTE_DEBUG=1

# Optional: Postgres connection URI (includes DB password) for one-off migrations locally.
# Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Used by: npm run db:apply-memory-align (Memory Engine column repair).
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-....pooler.supabase.com:5432/postgres

# TII 주간 Job · action-contract-escalation-expire 등: /api/cron/* 호출 시 인증. GitHub Actions cron에서 Bearer로 전달.
# action-contract-escalation-expire: bty-app/docs/ACTION_CONTRACT_ESCALATION_EXPIRE_CRON.md
CRON_SECRET=

# Arena leadership-engine action-loop QR token (mint/validate). Unset 시 CRON_SECRET 폴백.
ARENA_ACTION_LOOP_QR_SECRET=e489b02fbc5b7b7242bfb91d54f894b4af748a35d76f7d1c09cb878fd0aa08bd

# E2E: Playwright calls POST /api/test/cleanup-action-contracts with Bearer (E2E_TEST_CLEANUP_SECRET or CRON_SECRET).
# CI/GitHub Actions + deploy parity: ../docs/CI_SECRETS_CRON_E2E.md
# Local dev: NODE_ENV=development suffices. Preview/CI (next start): E2E_ALLOW_TEST_CLEANUP=1 + SUPABASE_SERVICE_ROLE_KEY on the app.
# Optional override for which user_id rows are deleted (default: shared BTY E2E UUID in route source).
# E2E_ACTION_CONTRACT_CLEANUP_USER_ID=
# E2E_TEST_CLEANUP_SECRET=

# Pool health cron: POST /api/cron/pool-health-metrics (SCENARIO_AUDIT_STANDARDS_V1 §3). Optional alert tuning:
# POOL_HEALTH_WARN_MAX_CHOICE_SHARE=0.85
# POOL_HEALTH_WARN_ZERO_EXIT_RATE=0.95
