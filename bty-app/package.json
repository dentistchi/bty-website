{
  "name": "bty-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/check-env.mjs",
    "build": "npm run prebuild && NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:local": "npm run prebuild && NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:fast": "npm run prebuild && SKIP_SOURCE_MAPS=1 NODE_OPTIONS='--max-old-space-size=4096' next build",
    "opennext:build": "opennextjs-cloudflare build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "deploy": "npm run prebuild && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "dev": "next dev",
    "clean": "rm -rf .next",
    "start": "next start",
    "lint": "tsc --noEmit",
    "lint:ux-flow-gb09": "node scripts/ux-flow-lock-gb09-sweep.mjs",
    "lint:terminology": "node scripts/terminology-lint.mjs",
    "lint:eslint": "next lint",
    "extract:questions": "node scripts/extract-questions.mjs",
    "test": "vitest run",
    "test:q237-smoke": "vitest run \"src/app/[locale]/bty-arena/q237-stub-routes.smoke.test.ts\" \"src/app/[locale]/bty-arena/q237-bty-arena-result.smoke.test.ts\" \"src/app/[locale]/my-page/q237-my-page-subroutes.smoke.test.ts\"",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:bty": "playwright test --project=bty-loop --project=bty-loop-step6-policy --project=bty-loop-step6-forced",
    "test:e2e:bty-step6": "playwright test --project=bty-loop-step6-policy --project=bty-loop-step6-forced --workers=1",
    "test:e2e:bty-step6:isolated": "PW_STEP6_ISOLATED=1 playwright test --project=bty-loop-step6-policy --project=bty-loop-step6-forced --workers=1",
    "test:e2e:three-contract-smoke": "playwright test --project=three-contract-smoke",
    "test:e2e:install": "playwright install chromium",
    "e2e:auth": "playwright test e2e/auth-three-contract.setup.ts --project=setup",
    "e2e:seed-fixture-user": "npx --yes tsx scripts/e2e-seed-fixture-user.ts",
    "e2e:seed-three-contract-users": "npx --yes tsx scripts/e2e-seed-three-contract-users.ts",
    "e2e:verify-fixture-email": "npx --yes tsx scripts/verify-e2e-fixture-email.ts",
    "test:e2e-three-contract-users": "vitest run src/engine/integration/e2e-three-contract-users.contract.test.ts",
    "e2e:seed-default-journey": "node scripts/e2e-seed-default-journey-profile.mjs",
    "e2e:seed-comeback": "node scripts/e2e-seed-comeback-profile.mjs",
    "e2e:auth:comeback": "playwright test e2e/auth-comeback.setup.ts --project=setup-comeback",
    "test:e2e:ci": "playwright test --project=chromium --project=chromium-comeback --reporter=line --workers=2",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:push": "supabase db push",
    "db:apply-memory-align": "npx tsx scripts/apply-memory-engine-align.ts",
    "storage:cors": "bash scripts/storage-cors.sh",
    "verify:avatar-composite-snapshot": "npx --yes tsx scripts/verify-avatar-composite-snapshot.ts",
    "verify:avatar-assets": "npx --yes tsx scripts/verify-avatar-assets.ts",
    "verify:avatar-assets:characters": "npx --yes tsx scripts/verify-avatar-assets.ts --characters-only",
    "verify:arena-release-gate": "bash scripts/arena-release-gate.sh",
    "seed:arena-release-gate-fixture": "npx --yes tsx scripts/seed-arena-release-gate-fixture.ts",
    "generate:avatar-manifest": "npx --yes tsx scripts/generate-avatar-manifest.ts",
    "embed:accessory-png-as-svg": "npx --yes tsx scripts/embed-accessory-png-as-svg.ts",
    "write:character-placeholder-pngs": "npx --yes tsx scripts/write-character-placeholder-pngs.ts",
    "generate:character-thumbs": "npx --yes tsx scripts/generate-character-thumbs.ts",
    "write:accessory-placeholders": "npx --yes tsx scripts/write-accessory-placeholders.ts",
    "e2e": "npx --yes tsx src/engine/integration/e2e-runner.ts",
    "bty:test-chain": "tsx src/scripts/bty-test-chain.ts",
    "sync:elite-from-chain": "npx --yes tsx scripts/sync-elite-from-chain-workspace.ts"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.95.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.0",
    "jose": "^5.9.6",
    "next": "15.5.7",
    "next-auth": "^5.0.0-beta.25",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@playwright/test": "1.49",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-links": "^8.4.0",
    "@storybook/nextjs": "^8.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.7",
    "jsdom": "^29.0.1",
    "pg": "^8.20.0",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "storybook": "^8.6.17",
    "supabase": "^2.83.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0",
    "webpack": "5.101.2",
    "wrangler": "^4.85.0"
  },
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "ajv": "^8.12.0",
    "webpack": "5.101.2"
  }
}
