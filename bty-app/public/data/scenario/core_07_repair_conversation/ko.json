{
  "id": "core_07_repair_conversation",
  "title": "첫 번째 진짜 리페어 대화",
  "role": "Office Manager",
  "pressure": "외부 노출 이후 의사와 어시스턴트를 함께 모았다. 모두 다른 해석을 가지고 있다. 어시스턴트는 부담을 느끼고, 의사는 평가받는 느낌을 받는다. 이 대화는 시스템을 리셋하거나 더 깨뜨릴 수 있다.",
  "conversation_frame": {
    "opening_position": "이 대화의 목적을 정의해야 한다.",
    "frame_options": [
      "감정 해소",
      "누가 잘못했는지 정리",
      "구조 리셋"
    ],
    "hidden_risk": "프레임을 정의하지 않으면 가장 강한 해석이 대화를 지배한다."
  },
  "tradeoff": "Comfort vs Structural Repair",
  "bty_tension_axis": "Comfort vs Truth vs Ownership",
  "difficulty_level": 5,
  "pattern_detection": [
    "emotional_release_loop",
    "truth_avoidance",
    "defensiveness",
    "ownership_conflict",
    "structure_creation"
